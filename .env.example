# Código de acceso — Si lo defines, los visitantes deben introducirlo para ver la web
# Vacío = sin barrera (útil en desarrollo)
PUBLIC_ACCESS_CODE=""

# Firebase — Configuración del proyecto (Capa gratuita)
# Copia este archivo a .env y rellena los valores desde la consola de Firebase:
# Proyecto → Configuración del proyecto → Tus apps → Configuración de SDK

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
