# Código de acceso — Si lo defines, los visitantes deben introducirlo para ver la web
# Vacío = sin barrera (útil en desarrollo)
PUBLIC_ACCESS_CODE=""

# Firebase — Configuración del proyecto (Capa gratuita)
# Copia este archivo a .env y rellena los valores desde la consola de Firebase:
# Proyecto → Configuración del proyecto → Tus apps → Configuración de SDK

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Spotify — ID público de la playlist
# Cómo obtenerlo: abre la playlist en Spotify → Compartir → Copiar enlace
# El ID es la parte tras /playlist/ en la URL: https://open.spotify.com/playlist/ESTE_ES_EL_ID
PUBLIC_SPOTIFY_PLAYLIST_ID=

# Spotify — Enlace colaborativo para que los invitados puedan añadir canciones
# Cómo obtenerlo: Spotify → tu playlist → (···) → Invitar colaboradores → Copiar enlace
# Formato: https://open.spotify.com/playlist/ID?si=...&pt=TOKEN
# Si se deja vacío, el botón enlaza a la playlist normal (sin colaboración)
PUBLIC_SPOTIFY_PLAYLIST_COLLAB_URL=

# IBAN — Número de cuenta para regalos
# Si se define aquí, sobreescribe el valor de event-config.ts (recomendado para producción)
# Formato con espacios: ES00 0000 0000 0000 0000 0000
# Si se deja vacío, se usa el valor hardcodeado en src/lib/event-config.ts
PUBLIC_IBAN=
