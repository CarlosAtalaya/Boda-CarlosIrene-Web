---
/**
 * Sección RSVP — Wrapper Astro para el formulario React multi-paso.
 */
import RSVPForm from '../forms/RSVPForm';
import { EVENT_CONFIG } from '../../lib/event-config';
---

<section class="px-6 py-[var(--spacing-section)]" id="rsvp">
  <div class="mx-auto max-w-xl">

    <!-- Cabecera de sección -->
    <div class="reveal-up text-center mb-12 space-y-4">
      <p class="font-sans text-[0.7rem] tracking-[0.35em] uppercase text-[#C5A059]">
        Confirma tu presencia
      </p>
      <div class="divider-gold w-24 mx-auto reveal-line"></div>

      <!-- Logo sutil como separador -->
      <img
        src="/branding-logo.png"
        alt=""
        aria-hidden="true"
        width="48"
        height="48"
        class="w-10 h-10 object-contain mx-auto opacity-25"
        loading="lazy"
      />
    </div>

    <!-- Formulario React hidratado en cliente -->
    <RSVPForm client:load />

  </div>
</section>
