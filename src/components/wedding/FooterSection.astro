---
/**
 * Footer editorial — fondo claro para mejor legibilidad del contacto.
 */
import WhatsAppButton from '../WhatsAppButton';
import { EVENT_CONFIG } from '../../lib/event-config';

const { novios, textos } = EVENT_CONFIG;
---

<footer class="bg-[#F3EFEA] border-t border-[#E8E3D9] text-[#2A2A2A] px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-xl text-center">

    <!-- Eyebrow -->
    <p class="font-sans text-xs uppercase tracking-[0.3em] text-[#8B4542] mb-6">
      Contacto
    </p>

    <!-- Mensaje principal -->
    <h2 class="font-serif text-3xl sm:text-4xl italic mb-8 text-[#2A2A2A]" style="font-size: var(--text-heading-lg);">
      ¿Dudas? Estamos a tu disposición
    </h2>

    <!-- Logo principal del branding (grande, protagonista al final) -->
    <div class="flex flex-col items-center gap-4 mb-10">
      <img
        src="/branding-logo.png"
        alt={`${novios.ella} y ${novios.el}`}
        aria-hidden="true"
        width="200"
        height="200"
        class="w-72 h-72 sm:w-96 sm:h-96 md:w-[30rem] md:h-[30rem] object-contain opacity-70"
        loading="lazy"
      />
      <p class="font-serif text-2xl tracking-[0.2em] text-[#8B4542]">
        {novios.ella}
        <span class="text-[#2A2A2A] font-light mx-1">&</span>
        {novios.el}
      </p>
    </div>

    <!-- Texto y contacto -->
    <p
      class="font-serif italic text-[#2A2A2A]/70 mb-8"
      style="font-size: var(--text-body);"
    >
      {textos.footerTexto}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <WhatsAppButton client:load flotante={false} contacto="carlos" />
      <WhatsAppButton client:load flotante={false} contacto="irene" />
    </div>

    <p
      class="font-sans text-[#2A2A2A]/50 tracking-widest mt-8"
      style="font-size: var(--text-small);"
    >
      {textos.footerCopyright}
    </p>

  </div>
</footer>
