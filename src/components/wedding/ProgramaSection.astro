---
/**
 * Sección del programa del día — Estructura idéntica a plantilla.
 * Timeline con iconos, alternancia izq/der, línea central.
 */
import { Heart, GlassWater, Utensils, Music, Users } from 'lucide-react';
import { EVENT_CONFIG } from '../../lib/event-config';

const { programa, lugar } = EVENT_CONFIG;

// Mapeo de descripciones a iconos (estilo plantilla)
const iconMap: Record<string, typeof Heart> = {
  'Llegada': Users,
  'Ceremonia': Heart,
  'Cóctel': GlassWater,
  'Cena': Utensils,
  'Baile': Music,
};

function getIcon(desc: string) {
  for (const [key, Icon] of Object.entries(iconMap)) {
    if (desc.toLowerCase().includes(key.toLowerCase())) return Icon;
  }
  return Heart;
}

// Títulos cortos estilo plantilla
const titleMap: Record<string, string> = {
  'Llegada y bienvenida de los invitados': 'Bienvenida',
  'Ceremonia civil': 'Ceremonia',
  'Cóctel de bienvenida': 'Cóctel',
  'Cena de celebración': 'Banquete',
  'Baile nupcial y fiesta': 'Fiesta',
};
function getTitle(desc: string) {
  return titleMap[desc] ?? desc.split(' ')[0];
}

// Alternancia right/left para cada item
const aligns = ['right', 'left', 'right', 'left', 'right'] as const;
---

<section id="programa" class="py-24 sm:py-32 px-4 bg-[#F3EFEA]">

  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-serif text-4xl md:text-5xl mb-6 text-[#2A2A2A]">El Programa</h2>
    <div class="w-12 h-px bg-[#8B4542] mx-auto mb-10"></div>
    <p class="font-sans font-light tracking-wide text-[#2A2A2A]/60 mb-20 max-w-lg mx-auto" style="font-size: var(--text-body);">
      Acompáñanos a celebrar nuestra historia en un día lleno de momentos inolvidables.
    </p>

    <div class="relative max-w-2xl mx-auto">
      <!-- Línea vertical central sutil conectora -->
      <div class="absolute left-[23px] md:left-1/2 transform md:-translate-x-1/2 h-full w-px bg-[#D9C5C5]"></div>

      <!-- Eventos Timeline (estructura plantilla) -->
      <div class="space-y-16">
        {programa.map((item, i) => {
          const Icon = getIcon(item.descripcion);
          const isRight = aligns[i % aligns.length] === 'right';
          const title = getTitle(item.descripcion);
          return (
            <div class={`relative flex items-start md:items-center w-full ${isRight ? 'md:flex-row-reverse' : ''}`}>
              {/* Línea timeline móvil */}
              {i < programa.length - 1 && (
                <div class="absolute left-[23px] top-12 bottom-[-4rem] w-px bg-[#D9C5C5] md:hidden"></div>
              )}

              <div class="hidden md:block md:w-1/2"></div>

              <!-- Icono central / punto de timeline -->
              <div class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 flex items-center justify-center w-12 h-12 bg-[#F9F8F6] border border-[#8B4542] rounded-full z-10 text-[#8B4542]">
                <Icon size={18} strokeWidth={1.5} />
              </div>

              <!-- Contenido -->
              <div class={`w-full pl-16 md:pl-0 md:w-1/2 flex flex-col ${isRight ? 'md:pr-12 md:items-end md:text-right' : 'md:pl-12 md:items-start md:text-left'} py-2`}>
                <span class="font-sans text-xs font-bold tracking-[0.1em] text-[#8B4542] mb-2">{item.hora}</span>
                <h3 class="font-serif text-2xl mb-2 text-[#2A2A2A]">{title}</h3>
                <p class="font-sans text-[#2A2A2A]/60 font-light text-sm leading-relaxed max-w-sm">{item.descripcion}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
