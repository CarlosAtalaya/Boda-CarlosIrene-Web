---
/**
 * Sección Dónde & Cuándo — Estructura idéntica a plantilla.
 * Grid 2 cols: texto + iconos | galería carrusel de fotos del restaurante.
 */
import { MapPin, Calendar, Clock, ExternalLink } from 'lucide-react';
import { EVENT_CONFIG } from '../../lib/event-config';
import { getVenueImageUrls } from '../../lib/venue-images';
import AddToCalendarButton from '../AddToCalendarButton';
import VenueGallery from './VenueGallery';

const { lugar, lugarDireccion, coordenadas, fechaLegible, horaInicio, lugarWeb } = EVENT_CONFIG;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(coordenadas)}`;
const venueImages = getVenueImageUrls();

// Formatear día de la semana y año (26 de junio de 2026 -> Viernes, Dos mil veintiséis)
const fechaDate = new Date(parseInt(EVENT_CONFIG.fecha.slice(0,4)), parseInt(EVENT_CONFIG.fecha.slice(4,6)) - 1, parseInt(EVENT_CONFIG.fecha.slice(6,8)));
const diaSemana = fechaDate.toLocaleDateString('es-ES', { weekday: 'long' });
const diaSemanaCap = diaSemana.charAt(0).toUpperCase() + diaSemana.slice(1);
const anioTexto = new Date(EVENT_CONFIG.fecha.slice(0,4) + '-01-01').toLocaleDateString('es-ES', { year: 'numeric' });
const anioPalabras = anioTexto === '2026' ? 'Dos mil veintiséis' : anioTexto;

// Hora legible (190000 -> 19:00)
const hora = `${horaInicio.slice(0,2)}:${horaInicio.slice(2,4)}`;
---

<section id="ubicacion" class="py-24 sm:py-32 px-6 paper-texture">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center">

      <!-- Diseño tipográfico y botones (order-2 en móvil para que mapa vaya primero) -->
      <div class="order-2 md:order-1 text-center md:text-left">
        <h2 class="font-serif text-4xl md:text-5xl mb-6 text-[#2A2A2A]">Dónde & Cuándo</h2>
        <div class="w-12 h-px bg-[#8B4542] mx-auto md:mx-0 mb-10"></div>

        <div class="space-y-8 mb-12 font-sans font-light">
          <div class="flex flex-col md:flex-row items-center md:items-start gap-4">
            <span class="text-[#8B4542] mt-1"><Calendar size={20} strokeWidth={1} /></span>
            <div>
              <h3 class="font-serif text-xl mb-1 text-[#2A2A2A]">{diaSemanaCap}, {fechaLegible.replace(/ de \d{4}$/, '')}</h3>
              <p class="text-[#2A2A2A]/60 text-sm tracking-wide">{anioPalabras}</p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row items-center md:items-start gap-4">
            <span class="text-[#8B4542] mt-1"><Clock size={20} strokeWidth={1} /></span>
            <div>
              <h3 class="font-serif text-xl mb-1 text-[#2A2A2A]">{hora} Horas</h3>
              <p class="text-[#2A2A2A]/60 text-sm tracking-wide">Se ruega puntualidad</p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row items-center md:items-start gap-4">
            <span class="text-[#8B4542] mt-1"><MapPin size={20} strokeWidth={1} /></span>
            <div>
              <h3 class="font-serif text-xl mb-1 text-[#2A2A2A]">{lugar}</h3>
              <p class="text-[#2A2A2A]/60 text-sm tracking-wide leading-relaxed">
                {lugarDireccion}
              </p>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start flex-wrap">
          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="min-h-[44px] inline-flex items-center justify-center bg-[#2A2A2A] text-white px-8 py-3 uppercase tracking-[0.2em] text-xs hover:bg-[#8B4542] transition-colors duration-300 text-center touch-manipulation"
          >
            Ver en Mapa
          </a>
          <a
            href={lugarWeb}
            target="_blank"
            rel="noopener noreferrer"
            class="min-h-[44px] border border-[#D9C5C5] text-[#2A2A2A] px-8 py-3 uppercase tracking-[0.2em] text-xs hover:border-[#2A2A2A] transition-colors duration-300 text-center inline-flex items-center justify-center gap-2 touch-manipulation"
          >
            <ExternalLink size={14} />
            Visitar web
          </a>
          <AddToCalendarButton className="min-h-[44px] border border-[#D9C5C5] hover:border-[#2A2A2A] rounded-none px-8 py-3 uppercase tracking-[0.2em] text-xs justify-center" />
        </div>
      </div>

      <!-- Galería carrusel: una imagen a la vez con flechas para navegar -->
      <div class="order-1 md:order-2 relative">
        <VenueGallery client:load images={venueImages} lugar={lugar} lugarWeb={lugarWeb} />
        <!-- Detalle estético superpuesto con el tono primario -->
        <div class="absolute -bottom-6 -left-6 w-32 h-32 border-b border-l border-[#8B4542] opacity-50 pointer-events-none"></div>
        <div class="absolute -top-6 -right-6 w-32 h-32 border-t border-r border-[#8B4542] opacity-50 pointer-events-none"></div>
      </div>

    </div>
  </div>
</section>
