---
/**
 * Hero — Sección de apertura con logo, nombres y fecha.
 * Scroll-driven animations + tipografía fluida.
 */
import { EVENT_CONFIG } from '../../lib/event-config';

const { novios, fechaCorta, fechaLegible, lugar, lugarDireccion } = EVENT_CONFIG;
const fechaParts = fechaLegible.split(' ');
const fechaHero = `${fechaParts[0]} ${fechaParts[2].toUpperCase()} ${fechaParts[4]} | ${lugarDireccion.split(',')[0].toUpperCase()}`;
---

<section
  id="hero"
  class="hero-warm paper-texture relative min-h-screen flex flex-col items-center justify-center px-4 sm:px-6 py-24 sm:py-20 overflow-hidden pt-28 sm:pt-24"
>
  <!-- Orbes decorativos (más presencia para dar cuerpo al fondo) -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-[#D9C5C5] mix-blend-multiply filter blur-[100px] opacity-40"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-[#8B4542] mix-blend-multiply filter blur-[100px] opacity-22"></div>
  </div>

  <!-- Logo branding disimulado (esquina, no protagonista) -->
  <figure class="absolute top-6 right-6 sm:top-8 sm:right-8 z-10 opacity-20" aria-hidden="true">
    <img
      src="/branding-logo.png"
      alt=""
      width="64"
      height="64"
      class="w-12 h-12 sm:w-14 sm:h-14 object-contain"
      loading="eager"
    />
  </figure>

  <!-- Eyebrow (invitación a boda) -->
  <p
    class="font-sans text-xs md:text-sm uppercase tracking-[0.4em] text-[#8B4542] mb-8 relative z-10"
  >
    Os invitan a su boda
  </p>

  <!-- Título principal — tipografía fluida -->
  <h1
    class="font-serif text-6xl md:text-8xl lg:text-9xl font-light text-center tracking-tight text-[#2A2A2A] leading-tight mb-4 relative z-10"
  >
    {novios.ella}
    <span class="block italic text-4xl md:text-6xl lg:text-7xl my-2 text-[#8B4542]">&amp;</span>
    {novios.el}
  </h1>

  <!-- Separador (estilo plantilla) -->
  <div class="w-px h-16 bg-[#2A2A2A] opacity-20 my-8 relative z-10"></div>

  <!-- Fecha y lugar (estilo plantilla) -->
  <p
    class="font-sans text-sm md:text-lg font-light tracking-[0.3em] text-[#2A2A2A] mb-12 relative z-10"
  >
    {fechaHero}
  </p>

  <!-- CTA Confirmar Asistencia (estilo plantilla: borde carbón, hover invertido) -->
  <a
    href="#rsvp"
    class="mt-10 relative z-10 inline-flex min-h-[44px] items-center justify-center border border-[#2A2A2A] text-[#2A2A2A] px-10 py-4 hover:bg-[#2A2A2A] hover:text-[#F9F8F6] transition-all duration-500 uppercase tracking-[0.2em] font-sans text-xs touch-manipulation"
  >
    Confirmar Asistencia
  </a>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <a href="#programa" class="text-[#8B4542] hover:text-[#2A2A2A] transition-colors">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
