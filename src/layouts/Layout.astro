---
/**
 * Layout base de la web de boda.
 * Incluye fuentes Google (Cormorant Garamond + Inter),
 * paleta de colores editorial, grain overlay, AccessGate y Navbar.
 */
import '../styles/global.css';
import AccessGate from '../components/AccessGate';
import Navbar from '../components/Navbar';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Irene & Carlos · 26 Junio', description = 'Nos casamos' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph (preview en WhatsApp, redes sociales, iMessage…) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
  </head>
  <body class="grain min-h-screen bg-[#F9F8F6] text-[#2A2A2A] font-sans antialiased">
    <AccessGate client:load>
      <Navbar client:load />
      <slot />
    </AccessGate>
  </body>
</html>
