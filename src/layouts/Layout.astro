---
/**
 * Layout base de la web de boda.
 * Incluye fuentes Google (Cormorant Garamond + Inter),
 * paleta de colores editorial, grain overlay, AccessGate y Navbar.
 */
import '../styles/global.css';
import AccessGate from '../components/AccessGate';
import Navbar from '../components/Navbar';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Irene y Carlos', description = 'Nos casamos' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="grain min-h-screen bg-[#F9F8F6] text-[#2A2A2A] font-sans antialiased">
    <AccessGate client:load>
      <Navbar client:load />
      <slot />
    </AccessGate>
  </body>
</html>
